<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_bg_medium"
    android:padding="14dp">

    <!-- Top Row: Time + Hijri + Weather -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- Time block -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1.2"
            android:orientation="vertical">

            <TextView
                android:id="@+id/widget_med_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--:--"
                android:textColor="#F0D060"
                android:textSize="32sp"
                android:textStyle="bold"
                android:fontFamily="serif"/>

            <TextView
                android:id="@+id/widget_med_hijri"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="-- هـ"
                android:textColor="#C9A227"
                android:textSize="10sp"/>

            <TextView
                android:id="@+id/widget_med_greg"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--"
                android:textColor="#8A8070"
                android:textSize="9sp"/>
        </LinearLayout>

        <!-- Vertical divider -->
        <View
            android:layout_width="1dp"
            android:layout_height="50dp"
            android:background="#22C9A227"
            android:layout_marginHorizontal="10dp"/>

        <!-- Weather block -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="0.7"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:id="@+id/widget_med_temp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--°"
                android:textColor="#4ECDC4"
                android:textSize="24sp"
                android:textStyle="bold"
                android:fontFamily="serif"/>

            <TextView
                android:id="@+id/widget_med_weather"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--"
                android:textColor="#8A8070"
                android:textSize="9sp"/>

            <!-- Moon phase -->
            <TextView
                android:id="@+id/widget_med_moon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🌙 --"
                android:textColor="#C9A227"
                android:textSize="9sp"
                android:layout_marginTop="2dp"/>
        </LinearLayout>

    </LinearLayout>

    <!-- Horizontal Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#22C9A227"
        android:layout_marginVertical="8dp"/>

    <!-- Prayer Times Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">

        <!-- Fajr -->
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="🌙" android:textSize="14sp" android:gravity="center"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="الفجر" android:textColor="#8A8070" android:textSize="8sp" android:gravity="center"/>
            <TextView android:id="@+id/widget_med_fajr" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:text="--:--"
                android:textColor="#E8DCC8" android:textSize="10sp" android:gravity="center"/>
        </LinearLayout>

        <!-- Dhuhr -->
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="☀️" android:textSize="14sp" android:gravity="center"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="الظهر" android:textColor="#8A8070" android:textSize="8sp" android:gravity="center"/>
            <TextView android:id="@+id/widget_med_dhuhr" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:text="--:--"
                android:textColor="#E8DCC8" android:textSize="10sp" android:gravity="center"/>
        </LinearLayout>

        <!-- Asr -->
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="🌤" android:textSize="14sp" android:gravity="center"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="العصر" android:textColor="#8A8070" android:textSize="8sp" android:gravity="center"/>
            <TextView android:id="@+id/widget_med_asr" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:text="--:--"
                android:textColor="#E8DCC8" android:textSize="10sp" android:gravity="center"/>
        </LinearLayout>

        <!-- Maghrib -->
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="🌇" android:textSize="14sp" android:gravity="center"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="المغرب" android:textColor="#8A8070" android:textSize="8sp" android:gravity="center"/>
            <TextView android:id="@+id/widget_med_maghrib" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:text="--:--"
                android:textColor="#E8DCC8" android:textSize="10sp" android:gravity="center"/>
        </LinearLayout>

        <!-- Isha -->
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="⭐" android:textSize="14sp" android:gravity="center"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="العشاء" android:textColor="#8A8070" android:textSize="8sp" android:gravity="center"/>
            <TextView android:id="@+id/widget_med_isha" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:text="--:--"
                android:textColor="#E8DCC8" android:textSize="10sp" android:gravity="center"/>
        </LinearLayout>

    </LinearLayout>

    <!-- Next prayer highlight -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginTop="6dp"
        android:background="@drawable/widget_next_prayer_bg"
        android:padding="4dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="الصلاة القادمة: "
            android:textColor="#8A8070"
            android:textSize="10sp"/>

        <TextView
            android:id="@+id/widget_med_next_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="--"
            android:textColor="#F0D060"
            android:textSize="10sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/widget_med_next_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="  --:--"
            android:textColor="#C9A227"
            android:textSize="10sp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="  ·  "
            android:textColor="#8A8070"
            android:textSize="10sp"/>

        <TextView
            android:id="@+id/widget_med_countdown"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="--:--:--"
            android:textColor="#8A8070"
            android:textSize="10sp"/>
    </LinearLayout>

</LinearLayout>
