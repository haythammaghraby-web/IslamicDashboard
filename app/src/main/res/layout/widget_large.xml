<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_bg_large"
    android:padding="16dp">

    <!-- Header: Bismillah -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="بسم الله الرحمن الرحيم"
        android:textColor="#C9A227"
        android:textSize="11sp"
        android:fontFamily="serif"
        android:gravity="center"
        android:layout_marginBottom="8dp"/>

    <!-- Row 1: Time + Date -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/widget_lg_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--:--"
                android:textColor="#F0D060"
                android:textSize="36sp"
                android:fontFamily="serif"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/widget_lg_ampm"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="صباحاً"
                android:textColor="#8A8070"
                android:textSize="10sp"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="end">

            <TextView
                android:id="@+id/widget_lg_hijri"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="-- هـ"
                android:textColor="#C9A227"
                android:textSize="12sp"
                android:fontFamily="serif"/>

            <TextView
                android:id="@+id/widget_lg_greg"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--"
                android:textColor="#8A8070"
                android:textSize="10sp"
                android:layout_marginTop="2dp"/>

            <!-- Weather -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="4dp">

                <TextView
                    android:id="@+id/widget_lg_temp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--°"
                    android:textColor="#4ECDC4"
                    android:textSize="18sp"
                    android:fontFamily="serif"/>

                <TextView
                    android:id="@+id/widget_lg_weather"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="  --"
                    android:textColor="#8A8070"
                    android:textSize="10sp"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp"
        android:background="#22C9A227" android:layout_marginVertical="10dp"/>

    <!-- Prayer Times - Full List -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="مواقيت الصلاة"
        android:textColor="#C9A227"
        android:textSize="11sp"
        android:fontFamily="serif"
        android:gravity="center"
        android:layout_marginBottom="6dp"/>

    <!-- Prayer rows -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:background="@drawable/widget_prayer_row_bg" android:padding="6dp"
        android:layout_marginBottom="3dp">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🌙 الفجر" android:textColor="#E8DCC8" android:textSize="11sp" android:layout_weight="1"/>
        <TextView android:id="@+id/widget_lg_fajr" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="--:--" android:textColor="#C9A227" android:textSize="11sp" android:textStyle="bold"/>
    </LinearLayout>

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:background="@drawable/widget_prayer_row_bg" android:padding="6dp"
        android:layout_marginBottom="3dp">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🌅 الشروق" android:textColor="#E8DCC8" android:textSize="11sp" android:layout_weight="1"/>
        <TextView android:id="@+id/widget_lg_sunrise" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="--:--" android:textColor="#8A8070" android:textSize="11sp"/>
    </LinearLayout>

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:background="@drawable/widget_prayer_row_bg" android:padding="6dp"
        android:layout_marginBottom="3dp">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="☀️ الظهر" android:textColor="#E8DCC8" android:textSize="11sp" android:layout_weight="1"/>
        <TextView android:id="@+id/widget_lg_dhuhr" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="--:--" android:textColor="#C9A227" android:textSize="11sp" android:textStyle="bold"/>
    </LinearLayout>

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:background="@drawable/widget_prayer_row_bg" android:padding="6dp"
        android:layout_marginBottom="3dp">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🌤 العصر" android:textColor="#E8DCC8" android:textSize="11sp" android:layout_weight="1"/>
        <TextView android:id="@+id/widget_lg_asr" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="--:--" android:textColor="#C9A227" android:textSize="11sp" android:textStyle="bold"/>
    </LinearLayout>

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:background="@drawable/widget_prayer_row_bg" android:padding="6dp"
        android:layout_marginBottom="3dp">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🌇 المغرب" android:textColor="#E8DCC8" android:textSize="11sp" android:layout_weight="1"/>
        <TextView android:id="@+id/widget_lg_maghrib" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="--:--" android:textColor="#C9A227" android:textSize="11sp" android:textStyle="bold"/>
    </LinearLayout>

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:background="@drawable/widget_prayer_row_bg" android:padding="6dp"
        android:layout_marginBottom="6dp">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="⭐ العشاء" android:textColor="#E8DCC8" android:textSize="11sp" android:layout_weight="1"/>
        <TextView android:id="@+id/widget_lg_isha" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="--:--" android:textColor="#C9A227" android:textSize="11sp" android:textStyle="bold"/>
    </LinearLayout>

    <!-- Countdown bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/widget_prayer_row_bg"
        android:padding="7dp"
        android:layout_marginBottom="8dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="المتبقي للصلاة القادمة"
            android:textColor="#8A8070"
            android:textSize="10sp"/>

        <TextView
            android:id="@+id/widget_lg_next_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="--"
            android:textColor="#F0D060"
            android:textSize="11sp"
            android:fontFamily="serif"
            android:textStyle="bold"
            android:layout_marginEnd="6dp"/>

        <TextView
            android:id="@+id/widget_lg_countdown"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="--:--"
            android:textColor="#C9A227"
            android:textSize="14sp"
            android:textStyle="bold"
            android:fontFamily="serif"/>
    </LinearLayout>

    <!-- Moon Phase row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/widget_prayer_row_bg"
        android:padding="7dp">

        <TextView
            android:id="@+id/widget_lg_moon_icon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🌙"
            android:textSize="18sp"
            android:layout_marginEnd="8dp"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="طور القمر"
                android:textColor="#8A8070"
                android:textSize="9sp"/>

            <TextView
                android:id="@+id/widget_lg_moon_phase"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--"
                android:textColor="#C9A227"
                android:textSize="11sp"
                android:fontFamily="serif"/>
        </LinearLayout>

        <TextView
            android:id="@+id/widget_lg_moon_day"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="اليوم --"
            android:textColor="#8A8070"
            android:textSize="10sp"/>
    </LinearLayout>

</LinearLayout>
